# ============== Client (Vite) – todas as chaves VITE_* são expostas no build ==============

# Supabase (obrigatório para auth e dados)
# URL do projeto: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Night Worker API: escolha UMA das opções abaixo
# Opção A (padrão): Supabase edge function — deriva automaticamente de VITE_SUPABASE_URL
VITE_NIGHTWORKER_API_URL=${VITE_SUPABASE_URL}/functions/v1/nightworker-prompts

# Opção B: Servidor externo (ex.: coder-ai.workfaraway.com)
# Descomente e substitua a linha acima se usar servidor externo:
# VITE_NIGHTWORKER_API_URL=https://coder-ai.workfaraway.com

# Token anon para auto-login no Night Worker (opcional; se não definir, configure em /nw/connect)
# VITE_NW_ANON_TOKEN=your-anon-token-here

# OpenAI (Smart Capture, RAG, geração de conteúdo) – usado pelas Edge Functions
VITE_OPENAI_API_KEY=your-openai-key-here

# Deepgram – transcrição de áudio (voice input). Obter em https://deepgram.com
# Se não definir, o botão de microfone pode usar reconhecimento do browser (Chrome/Edge/Safari)
VITE_DEEPGRAM_API_KEY=your-deepgram-api-key

# ============== Edge Functions (configurar no Supabase Dashboard → Edge Functions → Secrets) ==============
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# OPENAI_API_KEY=your-openai-key
